---
import { text } from "../../data/i18n";
import FallingSkills from "../FallingSkills";

const t = text.skills;

const allSkills = [
  { src: "/icons/languange/Html.png", name: "HTML5" },
  { src: "/icons/languange/Css-Vanila.png", name: "CSS3" },
  { src: "/icons/languange/Js.png", name: "JavaScript" },
  { src: "/icons/languange/Php.png", name: "PHP" },
  { src: "/icons/languange/mysql.svg", name: "MySQL" },
  { src: "/icons/framework/React.svg", name: "React" },
  { src: "/icons/framework/tailwindcss.svg", name: "Tailwind" },
  { src: "/icons/framework/Node.js-Logo.png", name: "Node.js" },
  { src: "/icons/framework/bootsrap.png", name: "Bootstrap" },
  { src: "/icons/framework/laravel.png", name: "Laravel" },
  { src: "/icons/framework/typescript-logo.png", name: "TypeScript" },
  { src: "/icons/tools/git_bash.svg", name: "Git" },
  { src: "/icons/tools/github.svg", name: "GitHub" },
  { src: "/icons/tools/vscode.svg", name: "VS Code" },
  { src: "/icons/tools/Vercel.svg", name: "Vercel" },
  { src: "/icons/tools/chatgpt.svg", name: "ChatGPT" },
  { src: "/icons/tools/google.svg", name: "Google" },
];
---

<section id="skills" class="py-28 md:py-36 relative overflow-hidden bg-[#121212]">
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16 md:mb-20">
      <div class="flex items-center gap-4 justify-center mb-8">
        <span class="h-px w-16 bg-gradient-to-r from-transparent to-[#D4AF37]/40"></span>
        <span class="text-[#D4AF37]/70 font-display tracking-[0.3em] text-[11px] uppercase font-semibold">
          Arsitektur & Alat
        </span>
        <span class="h-px w-16 bg-gradient-to-l from-transparent to-[#D4AF37]/40"></span>
      </div>

      <h2 class="lustre-text dark:lustre-dark lustre-light text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-5">
        {t.title}
      </h2>
    </div>

    <!-- Falling Skills -->
    <FallingSkills
      client:only="react"
      items={allSkills}
    />

  </div>
</section>
